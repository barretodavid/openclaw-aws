{
  "name": "openclaw",
  "private": true,
  "scripts": {
    "test": "pnpm -r run test:unit",
    "test:all": "pnpm run test && pnpm run ci",
    "ci": "AGENT_NAME=ci-$(date +%s) sh -c 'pnpm run deploy && pnpm --filter integration run test:run; STATUS=$?; pnpm run destroy; exit $STATUS'",
    "typecheck": "pnpm -r typecheck",
    "deploy": "pnpm --filter cdk run deploy",
    "synth": "pnpm --filter cdk run synth",
    "destroy": "pnpm --filter cdk run destroy",
    "login": "pnpm --filter cdk run login",
    "integration:deploy": "AGENT_NAME=test pnpm run deploy",
    "integration:destroy": "AGENT_NAME=test pnpm run destroy",
    "integration:run": "AGENT_NAME=test pnpm --filter integration run test:run",
    "integration:login": "AGENT_NAME=test pnpm run login"
  },
  "devDependencies": {
    "@tsconfig/node22": "22.0.5",
    "@types/jest": "29.5.14",
    "@types/node": "22.19.13",
    "dotenv": "17.3.1",
    "jest": "29.7.0",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
