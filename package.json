{
  "name": "openclaw",
  "private": true,
  "scripts": {
    "test": "pnpm run test:unit",
    "test:all": "pnpm run test:unit && pnpm run ci",
    "test:unit": "pnpm -r run test:unit",
    "test:integration": "pnpm --filter integration run test:run",
    "ci": "pnpm run deploy:test && pnpm --filter integration run test:run; STATUS=$?; pnpm run destroy:test; exit $STATUS",
    "typecheck": "pnpm -r typecheck",
    "deploy:prod": "pnpm --filter cdk run deploy:prod",
    "deploy:test": "pnpm --filter cdk run deploy:test",
    "synth": "pnpm --filter cdk run synth",
    "destroy:prod": "pnpm --filter cdk run destroy:prod",
    "destroy:test": "pnpm --filter cdk run destroy:test",
    "publish:proxy": "pnpm --filter openclaw-aws-proxy publish"
  },
  "devDependencies": {
    "@tsconfig/node22": "22.0.5",
    "@types/jest": "29.5.14",
    "@types/node": "22.19.13",
    "dotenv": "17.3.1",
    "jest": "29.7.0",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
