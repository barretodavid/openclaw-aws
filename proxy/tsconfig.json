{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["es2022"],
    "outDir": "dist",
    "declaration": false,
    "strict": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "inlineSourceMap": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
