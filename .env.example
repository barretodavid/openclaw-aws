# Agent name (required) - scopes all AWS resources. Must be lowercase alphanumeric + hyphens, start with a letter, max 20 chars.
AGENT_NAME=alice

# AWS Deployment
# Availability zone (required). The region is derived automatically (e.g., us-east-1a -> us-east-1).
CDK_AZ=us-east-1a

# LLM Provider (exactly one, required)
# Supported: venice, anthropic, openai, google, mistral, groq, xai, openrouter, cerebras
LLM_PROVIDER=venice
LLM_API_KEY=

# RPC Provider (exactly one, optional -- for Starknet on-chain access)
# Supported: alchemy, infura, cartridge, voyager
RPC_PROVIDER=alchemy
RPC_API_KEY=

# Web search provider (exactly one, required)
# Supported: brave, gemini, grok, kimi, perplexity
WEB_SEARCH_PROVIDER=brave
WEB_SEARCH_API_KEY=

# Telegram bot token (optional -- only needed for Telegram channel support)
# Get this from @BotFather on Telegram. If using Signal instead, leave blank.
TELEGRAM_BOT_TOKEN=
