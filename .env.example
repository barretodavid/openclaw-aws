# AWS Deployment
# Both availability zones are REQUIRED. The region is derived automatically (e.g., us-east-1a -> us-east-1).
# IMPORTANT: Prod and test AZs MUST be in different regions to avoid resource collisions
# (Secrets Manager, SSM parameters, and IAM roles are region-scoped, not VPC-scoped).
CDK_AZ_PROD=us-east-1a
CDK_AZ_TEST=us-east-2a

# LLM Provider (exactly one, required)
# Supported: venice, anthropic, openai, google, mistral, groq, xai, openrouter, cerebras
LLM_PROVIDER=venice
LLM_API_KEY=

# RPC Provider (exactly one, optional -- for Starknet on-chain access)
# Supported: alchemy, infura, cartridge, voyager
RPC_PROVIDER=alchemy
RPC_API_KEY=

# Web search provider (exactly one, required)
# Supported: brave, gemini, grok, kimi, perplexity
WEB_PROVIDER=brave
WEB_API_KEY=
