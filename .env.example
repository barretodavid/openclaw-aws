# AWS Deployment
# Both availability zones are REQUIRED. The region is derived automatically (e.g., us-east-1a → us-east-1).
# IMPORTANT: Prod and test AZs MUST be in different regions to avoid resource collisions
# (Secrets Manager, SSM parameters, and IAM roles are region-scoped, not VPC-scoped).
CDK_AZ_PROD=us-east-1a
CDK_AZ_TEST=us-east-2a

# LLM Providers (configure the ones you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
VENICE_API_KEY=
CEREBRAS_API_KEY=

# Web search
BRAVE_API_KEY=BSA3ns9ImRhEi1VcpQLBfMTehWsRnXk

# Starknet RPC Providers
ALCHEMY_API_KEY=
INFURA_API_KEY=
CARTRIDGE_API_KEY=
VOYAGER_API_KEY=
